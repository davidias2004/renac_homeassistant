# RENAC Power MCP Server — copy this to .env and fill in your credentials
#
# QUICK START: set only USERNAME + PASSWORD, then run discover_account()
# to find your STATION_ID and USER_ID automatically from the API.

RENAC_USERNAME=your_email@example.com
RENAC_PASSWORD=your_password

# Run discover_account() to get these values — no manual lookup needed
RENAC_STATION_ID=your_station_id
RENAC_USER_ID=your_user_id

# Optional: only needed if the default doesn't work for your region
# RENAC_BASE_URL=https://sec.bg.renacpower.cn:8084

# Optional: inverter serial number (enables get_inverter_detail and get_grid_chart)
# Run get_equipment_list() to find it after setting STATION_ID and USER_ID
# RENAC_EQU_SN=your_inverter_serial_number
